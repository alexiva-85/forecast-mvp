# Скопируйте в .env.local
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Опционально для npm run db:migrate (иначе подставится ref из скрипта)
# SUPABASE_PROJECT_REF=your_project_ref

# Только локально для npm test — не коммитить, не публиковать
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Мониторинг (G4) — опционально локально, обязательно в Vercel Production
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=forecast-mvp
# SENTRY_AUTH_TOKEN=...   # только CI/Vercel — загрузка source maps, не в git

# On-chain testnet (E5) — опционально, только локально / скрипты
# POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
# ONCHAIN_ADDRESS_PROFILE=reference
# ONCHAIN_DEPLOYER_PK=0x...          # deploy + write smoke — никогда в git
# ONCHAIN_SMOKE_WRITE=1
# ONCHAIN_RPC_SMOKE=1                 # vitest: RPC bytecode check
# NEXT_PUBLIC_ONCHAIN_CHAIN_ID=80002
# NEXT_PUBLIC_CTF_EXCHANGE_ADDRESS=0xE111180000d2663C0091e4f400237545B87B996B
# NEXT_PUBLIC_UMA_CTF_ADAPTER_ADDRESS=0x2F6f8DA6A21023E62399801945eed1b1975A4e12

# E6 — initialize UMA condition (npm run onchain:uma:init)
# UMA_INIT_TITLE=...
# UMA_INIT_OUTCOMES=Yes,No
# MARKET_SLUG=sandbox-test-market

# E7 — MM bot (npm run mm:seed)
# MM_BOT_EMAIL=mm-bot@forecast.local
# MM_BOT_PASSWORD=...              # required first run; never commit
# MM_MARKET_SLUGS=btc-150k-2026,real-madrid-ucl-2026
# MM_DRY_RUN=1
# MM_MID=0.5
# MM_SPREAD=0.02
# MM_LEVELS=3
# MM_SIZE=25
